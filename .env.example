# LLM configuration (Ollama — no API key required)
# Ollama must be running locally: https://ollama.com
LLM_API_URL=http://localhost:11434/v1/chat/completions
LLM_MODEL=llama3.2
LLM_TIMEOUT_SECONDS=120

# Retrieval configuration
Data_DOC_PATH=data/documents
RETRIEVAL_TOP_K=3
RETRIEVAL_MAX_TOP_K=10

# Logging configuration
LOG_FILE_PATH=logs/ai_backend.json
LOG_RETENTION_DAYS=30
LOG_CLEANUP_EVERY_N_WRITES=20
